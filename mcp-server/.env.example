# engineersTech MCP Server — Environment Variables

# Laravel backend base URL
LARAVEL_API_BASE=https://api.engineerstechbd.com/api/v1
LARAVEL_API_KEY=your-api-key-here

# Platform: stdio | chatgpt | tencent
MCP_ADAPTER=stdio

# ChatGPT adapter (HTTP server)
CHATGPT_PORT=3000

# Tencent adapter
TENCENT_PORT=3001

# WhatsApp sales number for lead redirect
WA_NUMBER=8801873722228

# Log level: debug | info | warn | error
LOG_LEVEL=info
